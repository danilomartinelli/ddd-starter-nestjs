{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".spec.ts$",
  "coverageDirectory": "./coverage",
  "setupFilesAfterEnv": ["./jest.setup.ts"],
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "tsconfig": {
          "allowJs": true,
          "esModuleInterop": true
        }
      }
    ]
  }
}
